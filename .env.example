# Required: set a strong random secret before running in production.
ABUAB_SECRET_KEY=replace-with-a-long-random-secret

# Optional local default is SQLite; set this in cloud for managed Postgres.
# Example: postgresql+psycopg://user:password@host:5432/dbname
DATABASE_URL=

# Optional: token lifetime in minutes.
ABUAB_ACCESS_TOKEN_EXPIRE_MINUTES=60
